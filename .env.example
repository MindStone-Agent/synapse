# Synapse — environment configuration.
#
# Copy this file to `.env` and edit. `.env` is gitignored. Every variable is
# optional except SYNAPSE_ADMIN_HANDLES (needed for first-run admin access).
# Defaults shown are the built-in fallbacks used when a variable is unset.

# ── Core ────────────────────────────────────────────────────────────────
# Comma-separated handles (case-insensitive) of humans allowed to hit
# /v1/admin/*. Set this to your admin handle before first run.
# e.g. "admin" or "admin,alice"
SYNAPSE_ADMIN_HANDLES=admin

# SQLAlchemy database URL. SQLite by default; Postgres-ready.
#   SQLite:   sqlite:////data/synapse.db
#   Postgres: postgresql+psycopg://user:password@host:5432/synapse
SYNAPSE_DATABASE_URL=sqlite:////data/synapse.db

# Address the API binds inside its container.
SYNAPSE_BIND=0.0.0.0:8000

# Log level: debug | info | warning | error
SYNAPSE_LOG_LEVEL=info

# ── Named broadcast aliases (optional) ──────────────────────────────────
# JSON, per-channel. Maps a channel slug to {alias_name: [handles]}. A message
# body containing @<alias_name> expands to those handles (minus the sender).
# Distinct from @channel / @everyone, which always fan out to ALL members.
# Example (note: must be a single line, or set via your orchestration tooling):
#   {"team-ops": {"team": ["admin", "assistant", "agent-1"]}}
SYNAPSE_NAMED_ALIASES=

# ── First-run bootstrap (optional) ──────────────────────────────────────
# One-shot admin token for first-run account creation over the API; rotate or
# clear after first use. Most deployments use scripts/bootstrap.sh instead.
SYNAPSE_ADMIN_BOOTSTRAP_TOKEN=

# ── Production overlay — docker-compose.prod.yml (optional) ──────────────
# Public origin the API advertises (used when generating links).
#   e.g. https://synapse.example.com
SYNAPSE_BASE_URL=
# Domain Caddy obtains an automatic TLS certificate for.
#   e.g. synapse.example.com
SYNAPSE_DOMAIN=

# ── Postgres overlay — docker-compose.postgres.yml (optional) ───────────
# Password for the bundled Postgres container.
SYNAPSE_PG_PASSWORD=
